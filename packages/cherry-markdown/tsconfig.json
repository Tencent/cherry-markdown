{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "rootDir": "./src",
    "strict": false,
    "noFallthroughCasesInSwitch": false,
    "paths": { "@/*": ["./src/*"], "~types/*": ["./types/*"] },
    "experimentalDecorators": true
  },
  "include": ["src/index.js", "src/index.core.js", "src/index.engine.js", "src/index.stream.js"],
  "exclude": ["**/node_modules/**", "src/libs/**/*", "dist"],
  "files": ["types/codemirror.d.ts", "types/env.d.ts"]
}
