{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/addons/types",
    "target": "ES2015",
    "module": "ESNext",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["src/*"],
      "@/libs/*": ["src/libs/*"],
      "~types/*": ["types/*"]
    }
  },
  "include": [
    "src/addons/**/*-plugin.js"
  ],
  "files": [
    "types/codemirror.d.ts",
    "types/global.d.ts"
  ]
}
